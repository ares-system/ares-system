# Assurance Run / ASST — primary chat path: LangChain ChatOpenRouter
# https://docs.langchain.com/oss/javascript/integrations/chat/openrouter
# Keys: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional — any OpenRouter model id: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Eval suites (`evals/*`, `pnpm test:eval:solana` — see evals/README.md)
# EVAL_RUNNER=openrouter

# Optional: LangSmith tracing (OpenRouter + agent calls)
# Create a key at https://smith.langchain.com — then set (LangChain JS / langsmith SDK):
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# Optional project tag:
# LANGSMITH_PROJECT=assurance-run
# Run a smoke script with tracing, e.g.:
#   LANGCHAIN_TRACING_V2=true LANGSMITH_TRACING=true pnpm exec tsx examples/assurance-run/openrouter-smoke.ts

# Used by some examples (e.g. examples/research/research-agent.ts)
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
