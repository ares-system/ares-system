{
  "name": "deepagentsjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Deep Agents - a library for building controllable AI agents with LangGraph",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./libs/*\" --filter \"./libs/providers/*\" build",
    "clean": "pnpm --filter \"./libs/*\" clean",
    "typecheck": "pnpm --filter \"./libs/*\" typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "pnpm format:check && pnpm lint && pnpm --filter \"./libs/*\" test",
    "test:unit": "pnpm --filter \"./libs/*\" test:unit && pnpm --filter \"@asst/assurance-run\" test && pnpm --filter \"@deepagents/eval-solana-vuln-rust\" test && pnpm --filter \"@deepagents/eval-solana-vuln-rust\" typecheck && pnpm --filter \"@deepagents/benchmark-tier-a\" typecheck",
    "test:eval": "pnpm --filter \"./evals/*\" test:eval",
    "test:eval:solana": "pnpm --filter \"@deepagents/eval-solana-vuln-rust\" test:eval",
    "benchmark:validate": "pnpm --filter \"@deepagents/benchmark-tier-a\" validate",
    "test:int": "pnpm --filter \"./libs/*\" --filter \"./libs/providers/*\" test:int",
    "test:watch": "pnpm --filter \"./libs/*\" test:watch",
    "test:coverage": "pnpm --filter \"./libs/*\" test:coverage && pnpm --filter \"@asst/assurance-run\" test:coverage",
    "changeset:version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "homepage": "https://docs.langchain.com/oss/javascript/deepagents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langchain-ai/deepagentsjs.git"
  },
  "keywords": [
    "ai",
    "agents",
    "langgraph",
    "langchain",
    "typescript",
    "llm"
  ],
  "author": "LangChain",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/langchain-ai/deepagentsjs/issues"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^25.5.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint",
    "*": "pnpm run format --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "overrides": {
      "@langchain/core": "1.1.41",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9 <10.2.1": "10.2.4",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": "5.5.10",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "lodash@<=4.17.23": "4.18.1",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "flatted@<3.4.2": "3.4.2",
      "axios@<1.15.0": "1.15.0",
      "langsmith@<=0.5.17": "0.5.18"
    }
  },
  "dependencies": {
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openrouter": "^0.2.2",
    "deepagents": "^1.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7"
  }
}
