{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
