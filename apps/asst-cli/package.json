{
  "name": "@asst/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "asst": "./dist/asst.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/asst.js",
    "dev": "tsx src/asst.ts",
    "test": "node --import tsx --test src/__tests__/engine.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@ares/engine": "workspace:*",
    "@clack/prompts": "^1.2.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "jiti": "^2.6.1"
  }
}
