# PostgreSQL (Railway / Fly Postgres / local)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Helius (dashboard.helius.dev) — backfill + webhook management API
HELIUS_API_KEY=
# Optional override (default mainnet enhanced API host)
# HELIUS_API_BASE=https://api-mainnet.helius-rpc.com

# Address to watch (program ID, wallet, or token mint — same as Helius webhook config)
WATCH_ADDRESS=

# HTTP server
PORT=8787

# Optional: require Authorization: Bearer <secret> or ?secret= on POST /webhooks/helius
# WEBHOOK_SHARED_SECRET=

# Backfill tuning
# BACKFILL_LIMIT=100
# BACKFILL_MAX_PAGES=500

# Evidence export metadata
# CHAIN_NETWORK=solana-mainnet

# ── Trigger classifier thresholds ──────────────────────────────────
# Minimum amount for `large_native_transfer` in lamports (1 SOL = 1e9).
# Default: 1_000_000_000_000 (1 000 SOL). Set to a huge number to disable.
# CHAIN_LARGE_NATIVE_LAMPORTS=1000000000000
#
# Minimum UI amount for `large_token_transfer` (already scaled by decimals).
# Default: 1_000_000 (tuned for stablecoins). Set high to disable.
# CHAIN_LARGE_TOKEN_UI_AMOUNT=1000000
