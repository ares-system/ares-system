{
  "name": "@asst/mcp-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "MCP (stdio) server exposing ASST assurance tools: Semgrep, SARIF merge, git summary, Solana RPC read, program analysis, manifest writer.",
  "bin": {
    "asst-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ares/engine": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
